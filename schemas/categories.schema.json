{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-frontend-studio.dev/schemas/categories.schema.json",
  "title": "Category Catalog",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "slug", "description", "tool_count"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "integer", "minimum": 1 },
      "name": { "type": "string" },
      "slug": { "type": "string", "pattern": "^[0-9a-z][a-z0-9-]*$" },
      "description": { "type": "string" },
      "tool_count": { "type": "integer", "minimum": 0 }
    }
  }
}
