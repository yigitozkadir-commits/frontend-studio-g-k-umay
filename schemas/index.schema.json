{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-frontend-studio.dev/schemas/index.schema.json",
  "title": "Tool Catalog Index",
  "description": "orchestration/index.json için şema.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "url", "category", "tags", "type", "priority", "when_to_use", "how_to_use"],
    "additionalProperties": true,
    "properties": {
      "id": { "type": "integer", "minimum": 1 },
      "name": { "type": "string" },
      "url": { "type": "string", "format": "uri" },
      "category": { "type": "string" },
      "tags": { "type": "array", "items": { "type": "string" } },
      "type": {
        "type": "string",
        "enum": ["library", "framework", "tool", "reference", "template", "boilerplate", "snippet", "starter"]
      },
      "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
      "when_to_use": { "type": "string" },
      "how_to_use": { "type": "string" },
      "related": { "type": "array", "items": { "type": "integer" } },
      "alternatives": { "type": "array", "items": { "type": "integer" } },
      "install_command": { "type": ["string", "null"] },
      "peer_dependencies": { "type": "array", "items": { "type": "string" } },
      "deprecated": { "type": "boolean" },
      "replacement_id": { "type": ["integer", "null"] },
      "bundle_kb": { "type": "number" },
      "ssr_safe": { "type": "boolean" },
      "rsc_safe": { "type": "boolean" },
      "maintenance": { "type": "string", "enum": ["active", "maintenance", "stale", "deprecated", "unknown"] },
      "learning_curve": { "type": "string", "enum": ["low", "medium", "high"] },
      "typescript": { "type": "boolean" },
      "score": { "type": "number", "minimum": 0, "maximum": 100 }
    }
  }
}
